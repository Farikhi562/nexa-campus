# Supabase - https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=support@nexatechlabs.my.id
ADMIN_EMAILS=founder@nexatechlabs.my.id

# Telegram reminder worker (optional for MVP/testing)
# App must keep working when these are empty.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=NEXACampusBot

# Tanya NEXA Lite - Gemini Free Tier (server-side only)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Cron/worker guard (optional)
CRON_SECRET=generate-a-long-random-secret
