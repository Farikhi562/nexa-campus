datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Tambahkan ini di dalam model User
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? // Wajib ada untuk NextAuth
  image         String?   // Wajib ada untuk NextAuth
  nim           String?   @unique
  name          String?
  tier          Int       @default(1)
  campus        String?  
  jurusan       String?
  angkatan      Int?
  createdAt     DateTime  @default(now())
  
  accounts      Account[] // Relasi baru untuk NextAuth
  sessions      Session[]
  moodLogs      MoodLog[]
  schedules     Schedule[]
}

model Schedule {
  id        String   @id @default(cuid())
  userId    String
  matkul    String
  day       String
  startTime String
  endTime   String
  room      String?
  dosenName String?
  campus    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  level     Int      // 1-5
  note      String?
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  source    String   
  category  String   
  createdAt DateTime @default(now())
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Tambahkan model Account ini
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}